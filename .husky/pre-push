#!/usr/bin/env sh

CHANGED=$(git diff --name-only origin/main...HEAD 2>/dev/null || true)

# ── Stale vitest snapshots (warning only) ────────────────────────────────────
if echo "$CHANGED" | grep -q 'packages/core/src/core/prompts\.ts'; then
  echo ''
  echo '===================================================='
  echo 'WARNING: packages/core/src/core/prompts.ts changed.'
  echo 'Vitest snapshots may be stale. If CI fails, run:'
  echo ''
  echo '  cd packages/core && npx vitest run src/core/prompts.test.ts --update'
  echo ''
  echo 'then commit the updated snapshots.'
  echo '===================================================='
fi
